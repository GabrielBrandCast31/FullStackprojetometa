# Variaveis usadas pelo docker-compose.yml (este arquivo deve estar na raiz
# do projeto). Renomeie para `.env` e edite para producao.
#
# Estas variaveis sao usadas em DOIS lugares pelo compose:
#   1) Para inicializar o container `postgres` (POSTGRES_USER etc.)
#   2) Para montar a DATABASE_URL que o backend usa para conectar no postgres
#
# Os SEGREDOS da aplicacao (JWT_SECRET, ADMIN_PASSWORD, ANTHROPIC_API_KEY)
# ficam em backend/.env — esse arquivo aqui eh so para o stack do compose.

POSTGRES_USER=dashmeta
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dashmeta
