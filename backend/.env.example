# Versao da Graph API do Meta. Atualize se a Meta descontinuar esta versao.
META_API_VERSION=v23.0

# Chave da API da Anthropic (Claude). Usada pelo endpoint /api/analyze.
# Pegue em https://console.anthropic.com/ -> Settings -> API Keys.
# Se ficar em branco, o app usa o motor de analise local (sem IA) como fallback.
ANTHROPIC_API_KEY=

# (Opcional) Modelo do Claude usado na analise.
ANTHROPIC_MODEL=claude-opus-4-7

# Chave secreta usada para assinar os tokens JWT de login.
# Gere uma chave aleatoria, por exemplo:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Senha de administrador exigida na pagina de cadastro de funcionarios.
# So quem souber esta senha consegue criar novos acessos ao dashboard.
ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# DATABASE_URL — usado pelo backend para conectar no Postgres.
#
# Em Docker (recomendado): NAO defina aqui. O docker-compose monta a URL
# automaticamente a partir das variaveis POSTGRES_* do .env da RAIZ do
# projeto (host="postgres", a rede interna do compose).
#
# Para rodar o backend FORA do docker (uvicorn direto), defina apontando
# para o Postgres local:
#   DATABASE_URL=postgresql://dashmeta:changeme@localhost:5432/dashmeta
DATABASE_URL=
